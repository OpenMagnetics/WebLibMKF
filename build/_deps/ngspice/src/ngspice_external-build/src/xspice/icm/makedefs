# -*- makefile -*-

# Edit this file to set global include paths,
# compiler info and subdirs

# Directory sturcture
SHELL = /bin/bash
srcdir = /home/alf/OpenMagnetics/WebLibMKF/build/_deps/ngspice/src/ngspice_external/src/xspice/icm
top_builddir = ../../..
top_srcdir = /home/alf/OpenMagnetics/WebLibMKF/build/_deps/ngspice/src/ngspice_external
subdir = src/xspice/icm
MKDIR_P = /usr/bin/mkdir -p
uname = $(shell uname)

# C compiler to use
CC = /home/alf/emsdk/upstream/emscripten/emcc
CFLAGS = -O2 -fwasm-exceptions -sSUPPORT_LONGJMP=wasm -fvisibility=hidden -std=gnu11
VIS_CFLAGS = 
EXEEXT = 
BUILD_EXEEXT = 

# Spice header include path
INCLUDES = -I$(top_builddir)/src/include -I$(top_srcdir)/src/include

# CFLAGS to use here
EXTRA_CFLAGS = -fPIC -Wshadow
DEPFLAGS = -MD -MF
ISMINGW = $(shell uname | grep -c "MINGW32")
ifeq ($(ISMINGW), 1)
  EXTRA_CFLAGS = -Wshadow
endif
ISCYGWIN = $(shell uname | grep -c "CYGWIN")
ifeq ($(ISCYGWIN), 1)
  EXTRA_CFLAGS =
endif
ISSUNOS = $(shell uname | grep -c "SunOS")
ifeq ($(ISSUNOS), 1)
  ifneq "$(CC)" "gcc"
    EXTRA_CFLAGS = -KPIC
    DEPFLAGS = -xMD -xMF
  endif
endif

# Path to the cmpp utility
CMPP = $(top_builddir)/src/xspice/cmpp/cmpp$(EXEEXT)

LIBS = -lm

# Flags to use when linking shared library
LDFLAGS = -shared
ifeq ($(ISMINGW), 1)
  LDFLAGS = -shared -fwasm-exceptions -sSUPPORT_LONGJMP=wasm
endif
ifeq "$(strip $(uname))" "Darwin"
  LDFLAGS = -bundle -flat_namespace -undefined suppress
endif
ifeq "$(strip $(uname))" "SunOS"
  ifneq "$(CC)" "gcc"
    LDFLAGS = -G
  endif
endif

# Install instructions

INSTALL = /usr/bin/install -c
INSTALL_DATA = ${INSTALL} -m 644
INSTALL_PROGRAM = ${INSTALL}

prefix = /home/alf/OpenMagnetics/WebLibMKF/build/_deps/ngspice/install
exec_prefix = ${prefix}
libdir = ${exec_prefix}/lib
pkglibdir = $(libdir)/ngspice
datarootdir = ${prefix}/share
datadir = ${datarootdir}
pkgdatadir = $(datadir)/ngspice

